<?xml version="1.0" encoding="utf-8"?>
<!--
    AWEB security: disable ALL cloud backup.
    Browser cookies/login sessions must never leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="all" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="all" />
    </device-transfer>
</data-extraction-rules>
